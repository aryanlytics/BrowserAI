{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // ── Language & Output ─────────────────────────────────────────────────────
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",

    // ── Libs ─────────────────────────────────────────────────────────────────
    // Node.js service — no DOM needed. @types/node provides process, fetch, etc.
    "lib": ["es2022"],
    "types": ["node"],

    // ── Emit ─────────────────────────────────────────────────────────────────
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "incremental": false,

    // ── Module interop ────────────────────────────────────────────────────────
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    // ── Strictness ───────────────────────────────────────────────────────────
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
