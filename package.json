{
  "name": "BrowserAI",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:voice": "turbo run dev --filter=web-frontend --filter=voice-service --filter=gemini-service",
    "dev:auth": "turbo run dev --filter=web-frontend --filter=auth-service",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=18"
  }
}
